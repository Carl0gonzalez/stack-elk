{
  "dashboard": {
    "title": "ELK Lab Dashboard",
    "description": "Dashboard para monitorear logs de la aplicación ELK Lab",
    "panels": [
      {
        "type": "visualization",
        "title": "Logs por Nivel",
        "visualization": {
          "type": "pie",
          "title": "Distribución de Logs por Nivel",
          "params": {
            "type": "pie",
            "addTooltip": true,
            "addLegend": true,
            "legendPosition": "right",
            "isDonut": false,
            "labels": {
              "show": false,
              "values": true,
              "last_level": true,
              "truncate": 100
            }
          },
          "aggs": [
            {
              "id": "1",
              "enabled": true,
              "type": "count",
              "schema": "metric",
              "params": {}
            },
            {
              "id": "2",
              "enabled": true,
              "type": "terms",
              "schema": "segment",
              "params": {
                "field": "level",
                "size": 5,
                "order": "desc",
                "orderBy": "1"
              }
            }
          ]
        }
      },
      {
        "type": "visualization",
        "title": "Logs por Endpoint",
        "visualization": {
          "type": "histogram",
          "title": "Logs por Endpoint",
          "params": {
            "type": "histogram",
            "grid": {
              "categoryLines": false,
              "style": {
                "color": "#eee"
              }
            },
            "categoryAxes": [
              {
                "id": "CategoryAxis-1",
                "type": "category",
                "position": "bottom",
                "show": true,
                "style": {},
                "scale": {
                  "type": "linear"
                },
                "labels": {
                  "show": true,
                  "filter": true,
                  "truncate": 100
                },
                "title": {}
              }
            ],
            "valueAxes": [
              {
                "id": "ValueAxis-1",
                "type": "value",
                "position": "left",
                "show": true,
                "style": {},
                "scale": {
                  "type": "linear",
                  "mode": "normal"
                },
                "labels": {
                  "show": true,
                  "rotate": 0,
                  "filter": false,
                  "truncate": 100
                },
                "title": {
                  "text": "Count"
                }
              }
            ],
            "seriesParams": [
              {
                "show": true,
                "type": "histogram",
                "mode": "stacked",
                "data": {
                  "label": "Count",
                  "id": "1"
                },
                "valueAxis": "ValueAxis-1",
                "drawLinesBetweenPoints": true,
                "lineWidth": 2,
                "interpolate": "linear",
                "showCircles": true
              }
            ],
            "addTooltip": true,
            "addLegend": true,
            "legendPosition": "right",
            "times": [],
            "addTimeMarker": false,
            "dimensions": {
              "x": {
                "accessor": 0,
                "format": {
                  "id": "string",
                  "params": {
                    "transform": "lowercase"
                  }
                },
                "params": {
                  "date": true,
                  "interval": "PT30S",
                  "intervalESValue": 30,
                  "intervalESUnit": "s",
                  "format": "HH:mm:ss",
                  "bounds": {
                    "min": "2023-01-01T00:00:00.000Z",
                    "max": "2023-12-31T23:59:59.999Z"
                  }
                },
                "aggType": "date_histogram"
              },
              "y": [
                {
                  "accessor": 1,
                  "format": {
                    "id": "number",
                    "params": {}
                  },
                  "params": {},
                  "aggType": "count"
                }
              ]
            }
          },
          "aggs": [
            {
              "id": "1",
              "enabled": true,
              "type": "count",
              "schema": "metric",
              "params": {}
            },
            {
              "id": "2",
              "enabled": true,
              "type": "date_histogram",
              "schema": "segment",
              "params": {
                "field": "@timestamp",
                "timeRange": {
                  "from": "now-1h",
                  "to": "now"
                },
                "useNormalizedEsInterval": true,
                "scaleMetricValues": false,
                "interval": "auto",
                "drop_partials": false,
                "min_doc_count": 1,
                "extended_bounds": {}
              }
            },
            {
              "id": "3",
              "enabled": true,
              "type": "terms",
              "schema": "group",
              "params": {
                "field": "path",
                "size": 5,
                "order": "desc",
                "orderBy": "1"
              }
            }
          ]
        }
      },
      {
        "type": "visualization",
        "title": "Errores por Hora",
        "visualization": {
          "type": "line",
          "title": "Errores por Hora",
          "params": {
            "type": "line",
            "grid": {
              "categoryLines": false,
              "style": {
                "color": "#eee"
              }
            },
            "categoryAxes": [
              {
                "id": "CategoryAxis-1",
                "type": "category",
                "position": "bottom",
                "show": true,
                "style": {},
                "scale": {
                  "type": "linear"
                },
                "labels": {
                  "show": true,
                  "filter": true,
                  "truncate": 100
                },
                "title": {}
              }
            ],
            "valueAxes": [
              {
                "id": "ValueAxis-1",
                "type": "value",
                "position": "left",
                "show": true,
                "style": {},
                "scale": {
                  "type": "linear",
                  "mode": "normal"
                },
                "labels": {
                  "show": true,
                  "rotate": 0,
                  "filter": false,
                  "truncate": 100
                },
                "title": {
                  "text": "Count"
                }
              }
            ],
            "seriesParams": [
              {
                "show": true,
                "type": "line",
                "mode": "normal",
                "data": {
                  "label": "Errors",
                  "id": "1"
                },
                "valueAxis": "ValueAxis-1",
                "drawLinesBetweenPoints": true,
                "lineWidth": 2,
                "interpolate": "linear",
                "showCircles": true
              }
            ],
            "addTooltip": true,
            "addLegend": true,
            "legendPosition": "right",
            "times": [],
            "addTimeMarker": false,
            "dimensions": {
              "x": {
                "accessor": 0,
                "format": {
                  "id": "string",
                  "params": {
                    "transform": "lowercase"
                  }
                },
                "params": {
                  "date": true,
                  "interval": "PT1H",
                  "intervalESValue": 1,
                  "intervalESUnit": "h",
                  "format": "HH:mm",
                  "bounds": {
                    "min": "2023-01-01T00:00:00.000Z",
                    "max": "2023-12-31T23:59:59.999Z"
                  }
                },
                "aggType": "date_histogram"
              },
              "y": [
                {
                  "accessor": 1,
                  "format": {
                    "id": "number",
                    "params": {}
                  },
                  "params": {},
                  "aggType": "count"
                }
              ]
            }
          },
          "aggs": [
            {
              "id": "1",
              "enabled": true,
              "type": "count",
              "schema": "metric",
              "params": {}
            },
            {
              "id": "2",
              "enabled": true,
              "type": "date_histogram",
              "schema": "segment",
              "params": {
                "field": "@timestamp",
                "timeRange": {
                  "from": "now-24h",
                  "to": "now"
                },
                "useNormalizedEsInterval": true,
                "scaleMetricValues": false,
                "interval": "PT1H",
                "drop_partials": false,
                "min_doc_count": 0,
                "extended_bounds": {}
              }
            },
            {
              "id": "3",
              "enabled": true,
              "type": "filter",
              "schema": "group",
              "params": {
                "query": "level:error"
              }
            }
          ]
        }
      }
    ]
  }
}
